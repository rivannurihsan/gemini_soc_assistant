<dashboard script="setup_page.js">
  <label>Gemini &amp; Gemma API Configuration (V2.0)</label>
  <row>
    <html>
      <div style="padding:20px; background:#fff; border:1px solid #ddd; border-radius:5px;">
        <h2>🛠️ Konfigurasi Model &amp; API</h2>
        
        <label>Google AI API Key:</label><br/>
        <input type="password" id="api_key_input" style="width:400px;" placeholder="Masukkan API Key baru..."/>
        <span id="key_info" style="margin-left:10px; font-size:12px;"></span><br/><br/>
        
        <label>Pilih Model AI:</label><br/>
        <select id="model_select" style="width:400px;">
          <option value="gemini-3.1-pro">Gemini 3.1 Pro (High-End Reasoning)</option>
          <option value="gemma-4-31B-it">Gemma 4 31B IT (Open Model Leader)</option>
          <option value="gemini-3-flash">Gemini 3 Flash (Fast Balanced)</option>
          <option value="gemma-4-26B-A4B-it">Gemma 4 26B A4B (Ultra Fast MoE)</option>
          <option value="shieldgemma-2">ShieldGemma 2 (Safety &amp; Moderation)</option>
        </select><br/><br/>

        <label>Role Analis Default:</label><br/>
        <select id="default_role_select" style="width:400px;"></select>
        
        <hr style="margin:25px 0;"/>
        
        <h2>🎭 Role Management</h2>
        <p>Definisikan instruksi sistem khusus untuk AI agar hasil analisis lebih tajam.</p>
        <input type="text" id="new_role_name" placeholder="Nama Role (misal: ahli_firewall)" style="width:400px;"/><br/><br/>
        <textarea id="role_instructions" placeholder="Instruksi sistem (System Prompt)..." style="width:100%; height:80px;"></textarea><br/>
        <button id="add_role_btn" class="btn btn-secondary">Simpan / Update Role</button>
        
        <div style="margin-top:30px; border-top:1px solid #eee; padding-top:20px;">
          <button id="save_btn" class="btn btn-primary">Terapkan Semua Konfigurasi</button>
          <span id="status_msg" style="margin-left:15px; font-weight:bold;"></span>
        </div>
      </div>
    </html>
  </row>
</dashboard>